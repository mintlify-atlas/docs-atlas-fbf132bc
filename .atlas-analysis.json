  "keyFeatures": [
    "2D nucleus detection using StarDist star-convex polygon model",
    "Fluent builder API for flexible configuration",
    "Support for H&E (RGB), fluorescence, and IHC images via preprocessing ops",
    "Global image normalization to avoid tile-boundary artifacts",
    "Cell expansion beyond nucleus boundary with optional Voronoi overlap resolution",
    "BioImage Model Zoo YAML spec auto-configuration",
    "Per-object intensity and shape measurements",
    "Multi-threaded tile-based inference with GPU memory management",
    "Bundled Groovy script templates for common use cases"
  ],
